<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Flags>
        <MainUnitHasCreateFormStatements Value="False"/>
        <MainUnitHasTitleStatement Value="False"/>
        <MainUnitHasScaledStatement Value="False"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="zrfisaac"/>
      <UseAppBundle Value="False"/>
      <ResourceType Value="res"/>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <MajorVersionNr Value="25"/>
      <MinorVersionNr Value="6"/>
      <RevisionNr Value="14"/>
      <BuildNr Value="1"/>
      <StringTable CompanyName="Isaac Caires Santana / zrfisaac.github.io" InternalName="zrfisaac.lazarus.base.shell" LegalCopyright="Isaac Caires Santana / zrfisaac.github.io" LegalTrademarks="Isaac Caires Santana / zrfisaac.github.io" OriginalFilename="zrfisaac" ProductName="zrfisaac.lazarus.base.shell" ProductVersion="25.6.14.1"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="LCLBase"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="zrfisaac.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="..\..\zrlib.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="zrfisaac"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="..\.."/>
    </SearchPaths>
    <Linking>
      <Debugging>
