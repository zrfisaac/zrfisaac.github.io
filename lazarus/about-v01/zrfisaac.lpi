<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <AutoCreateForms Value="False"/>
      <Title Value="ZRFISAAC"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <MajorVersionNr Value="1"/>
      <StringTable Comments="zrfisaac.lazarus.panel.v01" CompanyName="Isaac Caires / zrfisaac.github.io" FileDescription="zrfisaac.lazarus.panel.v01" InternalName="zrfisaac.lazarus.panel.v01" LegalCopyright="Isaac Caires / zrfisaac.github.io" LegalTrademarks="Isaac Caires / zrfisaac.github.io" OriginalFilename="zrfisaac" ProductName="zrfisaac.lazarus.panel.v01" ProductVersion="1.0.0.0"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Debug" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="zrfisaac.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="source\menu_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MenuMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit>
        <Filename Value="source\module_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModuleMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="DataModule"/>
      </Unit>
      <Unit>
        <Filename Value="library\menu_about.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MenuAbout"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="binary/debug/zrfisaac"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="source;library"/>
      <UnitOutputDirectory Value="object\debug"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
