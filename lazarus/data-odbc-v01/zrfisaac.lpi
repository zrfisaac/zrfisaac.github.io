<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <AutoCreateForms Value="False"/>
      <Title Value="ZRFISAAC"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <RevisionNr Value="1"/>
      <StringTable Comments="zrfisaac.lazarus.data.sqlite.v01" CompanyName="Isaac Caires / zrfisaac.github.io" FileDescription="zrfisaac.lazarus.data.sqlite.v01" InternalName="zrfisaac.lazarus.data.sqlite.v01" LegalCopyright="Isaac Caires / zrfisaac.github.io" LegalTrademarks="Isaac Caires / zrfisaac.github.io" OriginalFilename="zrfisaac" ProductName="zrfisaac.lazarus.data.sqlite.v01" ProductVersion="0.0.1.0"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Debug" Default="True"/>
      <Item Name="Linux64">
        <CompilerOptions>
          <Version Value="11"/>
          <PathDelim Value="\"/>
          <Target>
            <Filename Value="binary\linux64\zrfisaac"/>
          </Target>
          <SearchPaths>
            <IncludeFiles Value="$(ProjOutDir)"/>
            <OtherUnitFiles Value="source;library"/>
            <UnitOutputDirectory Value="object\linux64"/>
          </SearchPaths>
          <CodeGeneration>
            <Optimizations>
              <OptimizationLevel Value="3"/>
            </Optimizations>
          </CodeGeneration>
          <Linking>
            <Debugging>
              <GenerateDebugInfo Value="False"/>
              <RunWithoutDebug Value="True"/>
              <DebugInfoType Value="dsDwarf3"/>
              <UseLineInfoUnit Value="False"/>
            </Debugging>
            <Options>
              <Win32>
                <GraphicApplication Value="True"/>
              </Win32>
            </Options>
          </Linking>
        </CompilerOptions>
      </Item>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
      <Item>
        <PackageName Value="SQLDBLaz"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="zrfisaac.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="source\menu_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MenuMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit>
        <Filename Value="source\module_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModuleMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="DataModule"/>
      </Unit>
      <Unit>
        <Filename Value="library\menu_about.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MenuAbout"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="binary\debug\zrfisaac"/>
